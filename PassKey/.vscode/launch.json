{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Django Debug",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/examples/django_test_app/manage.py",
            "args": ["runserver", "0.0.0.0:8000"],
            "django": true,
            "justMyCode": true,
            "cwd": "${workspaceFolder}/examples/django_test_app",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/passkey-auth-core:${env:PYTHONPATH}"
            }
        }
    ]
}